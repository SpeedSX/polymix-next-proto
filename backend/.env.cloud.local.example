# Copy to .env.cloud.local (already gitignored via the root .gitignore's
# `.env.*.local` pattern — never commit the real file) and fill in the
# credentials you set on the SurrealDB Cloud instance. Then:
#
#   cd backend
#   set -a && source .env.cloud.local && set +a
#   PORT=8090 cargo run -p api
#
# This runs the api against SurrealDB Cloud instead of the local
# docker-compose SurrealDB `just dev` uses — a smoke test before deploying
# to Fly, or a candidate local-dev configuration in its own right (see
# docs/adr/0011-surrealdb-hosting-cloud-free-tier-instead-of-fly.md).

SURREALDB_URL=
SURREALDB_USER=
SURREALDB_PASS=
SURREALDB_NS=polymix
AUTH_DEV_MODE=true
